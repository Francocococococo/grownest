+  border-color: var(--role-border);
+  background: rgba(255, 255, 255, 0.92);
+}
+
+.app-feedback {
+  border: 1px solid transparent;
+  border-radius: 12px;
+  animation: feedback-in 260ms var(--ease-couch) both;
+}
